---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="页面未找到">
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-20 text-center">
    <div class="text-8xl font-serif text-[#37352F] mb-4">404</div>
    <h1 class="text-2xl font-serif text-[#37352F] mb-2">页面未找到</h1>
    <p class="text-[#787774] mb-8">抱歉，您访问的页面不存在或已被移除。</p>
    <a href="/" class="inline-block px-6 py-3 bg-[#E87722] text-white rounded-lg hover:bg-[#D06A1A] transition-colors">
      返回首页
    </a>
  </main>
  <Footer />
</BaseLayout>
