---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year
const postsByYear = allPosts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof allPosts>);
---

<BaseLayout title="归档 — Teloei's Blog">
  <Header slot="header" />
  <div class="max-w-article mx-auto px-5 py-10 md:py-16">
    <h1 class="text-3xl md:text-h1 font-serif text-charcoal dark:text-warm-50 mb-10">归档</h1>

    <div class="space-y-12">
      {Object.entries(postsByYear).sort(([a], [b]) => Number(b) - Number(a)).map(([year, posts]) => (
        <div>
          <h2 class="text-2xl font-serif text-terra mb-6">{year}</h2>
          <div class="space-y-3">
            {posts.map(post => (
              <a href={`/blog/${post.slug}`} class="group flex items-baseline gap-4 py-2 border-b border-warm-100 dark:border-warm-800 hover:border-terra/30 transition-colors">
                <time class="shrink-0 text-sm text-warm-400 w-20">
                  {post.data.date.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                </time>
                <span class="font-serif text-charcoal dark:text-warm-50 group-hover:text-terra transition-colors">
                  {post.data.title}
                </span>
                {post.data.tags.length > 0 && (
                  <span class="hidden sm:inline text-xs text-warm-400">
                    {post.data.tags[0]}
                  </span>
                )}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>
