---
export interface Props {
  title: string;
  slug: string;
  date: Date;
  tags?: string[];
  excerpt?: string;
  image?: string;
}

const { title, slug, date, tags = [], excerpt = '', image } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<a href={`/blog/${slug}/`} class="group block bg-white dark:bg-warm-800 rounded-card border border-warm-100 dark:border-warm-700 overflow-hidden hover:shadow-soft-md hover:-translate-y-1 transition-all duration-200">
  {image && (
    <div class="aspect-video overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    </div>
  )}
  <div class="p-5">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, 2).map(tag => (
          <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-terra/10 text-terra">{tag}</span>
        ))}
      </div>
    )}
    <h3 class="font-serif text-lg text-charcoal dark:text-warm-50 group-hover:text-terra transition-colors mb-2 line-clamp-2">{title}</h3>
    {excerpt && (
      <p class="text-sm text-warm-500 line-clamp-2 mb-3">{excerpt}</p>
    )}
    <div class="flex items-center justify-between text-xs text-warm-400">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="inline-flex items-center gap-1" data-views-slug={slug}>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span>-</span>
      </span>
    </div>
  </div>
</a>

<script>
  // 批量获取文章浏览量
  document.addEventListener('astro:page-load', () => {
    const elements = document.querySelectorAll('[data-views-slug]');
    if (elements.length === 0) return;
    const slugs = Array.from(elements).map(el => el.dataset.viewsSlug);
    // 分批请求避免 URL 过长
    Promise.all(slugs.map(slug =>
      fetch(`/api/views?slug=${encodeURIComponent(slug)}`)
        .then(r => r.json())
        .then(data => ({ slug, views: data.views }))
        .catch(() => ({ slug, views: 0 }))
    )).then(results => {
      results.forEach(({ slug, views }) => {
        const el = document.querySelector(`[data-views-slug="${slug}"] span`);
        if (el) el.textContent = views;
      });
    });
  });
</script>
