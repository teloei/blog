---

---

<footer class="border-t border-warm-200 dark:border-warm-700 mt-16">
  <div class="max-w-page mx-auto px-5 py-12">
    <div class="grid md:grid-cols-3 gap-10">
      <!-- 品牌 -->
      <div>
        <a href="/" class="font-serif text-xl text-charcoal dark:text-warm-50 hover:text-terra transition-colors">Teloei's Blog</a>
        <p class="mt-3 text-sm text-warm-500 leading-relaxed">记录技术、思考与生活。<br/>用文字丈量世界。</p>
      </div>

      <!-- 导航 -->
      <div>
        <h4 class="text-sm font-semibold text-charcoal dark:text-warm-50 mb-4">导航</h4>
        <nav class="space-y-2">
          <a href="/" class="block text-sm text-warm-500 hover:text-terra transition-colors">首页</a>
          <a href="/blog/" class="block text-sm text-warm-500 hover:text-terra transition-colors">所有文章</a>
          <a href="/archive/" class="block text-sm text-warm-500 hover:text-terra transition-colors">归档</a>
          <a href="/tags/" class="block text-sm text-warm-500 hover:text-terra transition-colors">标签</a>
          <a href="/about/" class="block text-sm text-warm-500 hover:text-terra transition-colors">关于</a>
        </nav>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="text-sm font-semibold text-charcoal dark:text-warm-50 mb-4">订阅更新</h4>
        <p class="text-sm text-warm-500 mb-3">新文章发布时收到邮件通知。</p>
        <form id="newsletter-form" class="flex gap-2">
          <input type="email" placeholder="your@email.com" required
            class="flex-1 min-w-0 px-3 py-2 text-sm border border-warm-200 dark:border-warm-700 rounded-input bg-warm-50 dark:bg-warm-900 text-charcoal dark:text-warm-50 focus:border-terra focus:ring-2 focus:ring-terra/10 outline-none transition-all" />
          <button type="submit"
            class="px-4 py-2 bg-terra text-white text-sm font-medium rounded-btn hover:bg-terra-dark transition-colors whitespace-nowrap">
            订阅
          </button>
        </form>
        <p id="newsletter-msg" class="hidden mt-2 text-xs"></p>
      </div>
    </div>

    <!-- 底部 -->
    <div class="mt-10 pt-6 border-t border-warm-100 dark:border-warm-800 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-warm-400">© {new Date().getFullYear()} Teloei. Built with Astro.</p>
      <div class="flex items-center gap-4">
        <a href="/rss.xml" class="text-xs text-warm-400 hover:text-terra transition-colors">RSS</a>
        <a href="https://github.com/teloei" target="_blank" rel="noopener" class="text-xs text-warm-400 hover:text-terra transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('newsletter-form');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = document.getElementById('newsletter-msg')!;
      msg.classList.remove('hidden');
      try {
        const email = (form.querySelector('input[type="email"]') as HTMLInputElement).value;
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();
        msg.textContent = res.ok ? '✓ ' + data.message : '✗ ' + data.error;
        msg.className = msg.className.replace(/text-\w+-\d+/g, '') + (res.ok ? ' text-green-600' : ' text-red-500');
        if (res.ok) (form.querySelector('input[type="email"]') as HTMLInputElement).value = '';
      } catch {
        msg.textContent = '✗ 网络错误，请重试';
        msg.className = msg.className.replace(/text-\w+-\d+/g, '') + ' text-red-500';
      }
    });
  });
</script>
